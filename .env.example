# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co        # Supabase project URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key                      # Supabase public anon key (safe to expose)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key                  # Supabase service role key (server-side only, never expose)

# ─── Anthropic (Claude AI) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...                                     # Claude API key for chatbot, aftercare generation, prep guide generation

# ─── Resend (Transactional Email) ────────────────────────────────────────────
RESEND_API_KEY=re_...                                            # Resend API key for aftercare emails, prep guides, follow-ups

# ─── Stripe (Billing) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...                                    # Stripe secret key (use sk_test_ for development)
STRIPE_WEBHOOK_SECRET=whsec_...                                  # Stripe webhook signing secret (from Stripe dashboard → Webhooks)
STRIPE_PRICE_STARTER_MONTHLY=price_...                           # Stripe Price ID for Starter plan (monthly)
STRIPE_PRICE_STARTER_ANNUAL=price_...                            # Stripe Price ID for Starter plan (annual)
STRIPE_PRICE_PRO_MONTHLY=price_...                               # Stripe Price ID for Pro plan (monthly)
STRIPE_PRICE_PRO_ANNUAL=price_...                                # Stripe Price ID for Pro plan (annual)

# ─── Twilio (SMS Emergency Alerts) ───────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx            # Twilio account SID
TWILIO_AUTH_TOKEN=your-auth-token                                # Twilio auth token
TWILIO_PHONE_NUMBER=+15550000000                                 # Twilio sending phone number (must be verified)

# ─── App Config ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.com                       # Public base URL of the app (used in emails, healing chat links)
NEXT_PUBLIC_GIPHY_API_KEY=your-giphy-key                        # Giphy API key (used in loyalty/celebrations UI)
NEXT_PUBLIC_SHOW_LOYALTY=false                                   # Feature flag — set to "true" to show the Loyalty tab

# ─── Admin & Cron ────────────────────────────────────────────────────────────
ADMIN_SECRET=your-admin-secret                                   # Secret header value for /api/admin/* routes
BLUEROOM_ADMIN_SECRET=your-blueroom-secret                       # Secret for Blueroom admin endpoints
CRON_SECRET=your-cron-secret                                     # Bearer token expected by /api/cron/* routes (set in Vercel Cron config)

# ─── Beehiiv (Newsletter) ────────────────────────────────────────────────────
BEEHIIV_API_KEY=your-beehiiv-key                                 # Beehiiv API key for newsletter signup
BEEHIIV_PUBLICATION_ID=pub_...                                   # Beehiiv publication ID
